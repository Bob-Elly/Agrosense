# AgroSense — Project .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build outputs ─────────────────────────────────────────────────────────────
client/dist/
client/.vite/

# ── Environment files (NEVER commit real secrets!) ────────────────────────────
.env
client/.env
server/.env

# ── Firebase service account key (contains private keys) ─────────────────────
server/serviceAccountKey.json

# ── OS/editor artifacts ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
