# server environment variables — copy this to .env and fill in your real values
# Never commit the actual .env file to version control!

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Firebase Admin SDK ─────────────────────────────────────────────────────
# Option 1 (cloud deployment) — set these three individually:
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
#
# Option 2 (local dev fallback) — point to the downloaded JSON file:
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json


# ─── Google Gemini API ───────────────────────────────────────────────────────
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Africa's Talking (SMS fallback) ────────────────────────────────────────
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_africas_talking_username
AT_ENVIRONMENT=sandbox

# ─── CORS ───────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
