# Client-side Firebase environment variables
# Create a copy of this file named ".env" and fill in your real values.
# Vite exposes only variables prefixed with VITE_ to the browser.

VITE_FIREBASE_API_KEY=your_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend API base URL (proxied through Vite in dev, real URL in production)
VITE_API_BASE_URL=http://localhost:5000
